<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's V8 JavaScript engine -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for Electron's internal memory management -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for better-sqlite3 and other native modules -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Required for Claude Code CLI subprocess -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Network access for Claude API and local services -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- File system access for project directories -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
  </dict>
</plist>
