{
  "name": "memory-plugin",
  "version": "1.0.0",
  "displayName": "Branch Memory",
  "description": "Displays Claude Code's native /memory entries stored per branch in .claude/CLAUDE_{branch}.md",
  "main": "index.js",
  "author": "Puffin",
  "license": "MIT",
  "keywords": ["memory", "knowledge-extraction", "domain-knowledge", "branch-memory"],
  "renderer": {
    "entry": "renderer/components/index.js",
    "components": [
      {
        "name": "MemoryView",
        "export": "MemoryView",
        "type": "class",
        "description": "Branch memory viewer and management interface"
      }
    ]
  },
  "extensionPoints": {
    "actions": [
      "memoryGetBranch",
      "memoryClearBranch"
    ],
    "ipcHandlers": [
      "memory-plugin:list-branches",
      "memory-plugin:get-branch-memory",
      "memory-plugin:clear-branch-memory"
    ],
    "components": [
      "MemoryView"
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "memory-view",
        "name": "Memory",
        "location": "nav",
        "icon": "🧠",
        "order": 75,
        "component": "MemoryView"
      }
    ],
    "commands": [],
    "menus": {},
    "configuration": {
      "title": "Memory Plugin Settings",
      "properties": {}
    }
  },
  "activationEvents": [
    "onStartup"
  ]
}
